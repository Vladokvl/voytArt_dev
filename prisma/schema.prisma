// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

// ── Enums ─────────────────────────────────────────────────────────────────────
enum MediaType {
    IMAGE
    VIDEO
}

// ── Authors ───────────────────────────────────────────────────────────────────
model Author {
    id        Int     @id @default(autoincrement())
    firstName String  @map("first_name")
    lastName  String  @map("last_name")
    bio       String?
    photoUrl  String? @map("photo_url")
    photoPublicId String @default("") @map("photo_public_id")

    paintings   Painting[]
    collections Collection[]
    products    Product[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("authors")
}

// ── Collections ───────────────────────────────────────────────────────────────
model Collection {
    id            Int     @id @default(autoincrement())
    title         String
    coverPhotoUrl String? @map("cover_photo_url")
    coverPhotoPublicId String @default("") @map("cover_photo_public_id")

    author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)
    authorId Int    @map("author_id")

    paintings Painting[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("collections")
}

// ── Paintings ─────────────────────────────────────────────────────────────────
model Painting {
    id          Int     @id @default(autoincrement())
    title       String
    description String?

    coverUrl String @map("cover_url")
    coverPublicId String @default("") @map("cover_public_id")

    hasNeon   Boolean @default(false) @map("has_neon")
    isForSale Boolean @default(false) @map("is_for_sale")
    sortOrder Int     @default(0) @map("sort_order")
    year      Int?

    author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)
    authorId Int    @map("author_id")

    collection   Collection? @relation(fields: [collectionId], references: [id])
    collectionId Int?        @map("collection_id")

    media PaintingMedia[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("paintings")
}

// ── Painting Media ────────────────────────────────────────────────────────────
model PaintingMedia {
    id     Int       @id @default(autoincrement())
    url    String
    publicId String  @default("") @map("public_id")
    isNeon Boolean   @default(false) @map("is_neon")
    order  Int       @default(0)
    type   MediaType @default(IMAGE)

    painting   Painting @relation(fields: [paintingId], references: [id], onDelete: Cascade)
    paintingId Int      @map("painting_id")

    @@map("painting_media")
}

// ── Shop Categories ───────────────────────────────────────────────────────────
model Category {
    id   Int    @id @default(autoincrement())
    name String @unique
    slug String @unique

    products Product[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("categories")
}

// ── Shop Products ─────────────────────────────────────────────────────────────
model Product {
    id          Int     @id @default(autoincrement())
    title       String
    description String?
    price       Float
    stock       Int     @default(0)
    sortOrder   Int     @default(0) @map("sort_order")
    isFeatured  Boolean @default(false) @map("is_featured")

    coverUrl      String @default("") @map("cover_url")
    coverPublicId String @default("") @map("cover_public_id")

    category   Category @relation(fields: [categoryId], references: [id])
    categoryId Int      @map("category_id")

    author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)
    authorId Int    @map("author_id")

    images ProductImage[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("products")
}

// ── Product Images ────────────────────────────────────────────────────────────
model ProductImage {
    id    Int    @id @default(autoincrement())
    url   String
    publicId String @default("") @map("public_id")
    order Int    @default(0)

    product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
    productId Int     @map("product_id")

    @@map("product_images")
}

// ── Gallery Posts ─────────────────────────────────────────────────────────────
model GalleryPost {
    id       Int       @id @default(autoincrement())
    title    String
    content  String
    coverUrl String?   @map("cover_url")
    coverPublicId String @default("") @map("cover_public_id")
    date     DateTime?

    media GalleryPostMedia[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("gallery_posts")
}

// ── Gallery Post Media ────────────────────────────────────────────────────────
model GalleryPostMedia {
    id    Int       @id @default(autoincrement())
    url   String
    publicId String @default("") @map("public_id")
    type  MediaType @default(IMAGE)
    order Int       @default(0)

    post   GalleryPost @relation(fields: [postId], references: [id], onDelete: Cascade)
    postId Int         @map("post_id")

    @@map("gallery_post_media")
}

// ── Admin ─────────────────────────────────────────────────────────────────────
model AdminUser {
    id           String @id @default(cuid())
    email        String @unique
    passwordHash String @map("password_hash")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("admin_users")
}
